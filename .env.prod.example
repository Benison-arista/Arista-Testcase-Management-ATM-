# Copy to .env.prod and fill in real values before deploying.
# NEVER commit .env.prod to git.

# PostgreSQL password for the 'atm' database user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Backend JWT — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h
DB_POOL_MAX=20

# Public origin browsers use to reach the app (no trailing slash)
CORS_ORIGIN=http://YOUR_SERVER_IP_OR_DOMAIN:5173
